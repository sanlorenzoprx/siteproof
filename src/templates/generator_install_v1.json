  "ai_prompt_set": {
    "photo_labeling": {
      "enabled": true,
      "label_hints": [
        "meter",
        "main_panel",
        "transfer_switch",
        "generator_pad",
        "fuel_line",
        "grounding",
        "serial_number",
        "permit",
        "site_overview",
        "clearance"
      ],
      "output_schema": "photo_label_result_v1"
    },
    "voice_note_structuring": {
      "enabled": true,
      "detect_materials": true,
      "detect_issues": true,
      "detect_change_orders": true,
      "supported_languages": ["en", "es"],
      "output_schema": "voice_note_result_v1"
    },
    "report_narrative": {
      "enabled": true,
      "tone": "professional_contractor",
      "max_words": 250,
      "output_schema": "report_narrative_result_v1"
    },
    "missing_proof_detection": {
      "enabled": true,
      "output_schema": "missing_proof_result_v1"
    }
  },
  "jurisdiction_modifiers": [
    {
      "modifier_id": "cross_jurisdiction_warning",
      "display_name": "Business and jobsite jurisdiction mismatch",
      "applies_when": {
        "field": "jobsite_zip",
        "operator": "not_equals",
        "value": "business_zip"
      },
      "actions": [
        {
          "action_type": "add_validation_rule",
          "validation_rule": {
            "rule_id": "verify_jobsite_ahj",
            "rule_type": "jurisdiction_warning",
            "severity": "warning",
            "display_message": "Jobsite ZIP may fall under a different AHJ than business ZIP. Verify permit and inspection requirements for the jobsite location.",
            "applies_to": ["inspector_packet", "internal_record"],
            "conditions": [],
            "recommended_action": "Review jobsite AHJ, permit office, utility provider, and inspection scheduling requirements."
          }
        }
      ],
      "source_requirement": "job_context",
      "confidence_level": "high"
    },
    {
      "modifier_id": "coastal_wind_zone_anchoring_proof",
      "display_name": "Coastal wind-zone anchoring proof",
      "applies_when": {
        "field": "jurisdiction.wind_zone_notes",
        "operator": "exists"
      },
      "actions": [
        {
          "action_type": "add_proof_requirement",
          "stage_id": "active_work",
          "proof_requirement": {
            "requirement_id": "anchoring_detail_photo",
            "proof_type": "photo",
            "priority": "required",
            "display_name": "Generator anchoring detail",
            "field_instruction": "Capture clear photo of generator anchoring detail before final closeout.",
            "capture_hint": "Show fastening/anchoring detail and surrounding base context.",
            "minimum_count": 1,
            "maximum_count": 6,
            "allow_multiple": true,
            "requires_gps": true,
            "requires_timestamp": true,
            "requires_user_note": false,
            "requires_ai_quality_check": true,
            "quality_rules": ["not_blurry", "not_dark"],
            "ai_label_hints": ["anchoring", "fastener", "base", "wind_zone"],
            "inspection_tags": ["anchoring", "wind_zone"],
            "permit_tags": ["site_plan", "final_inspection"],
            "export_tags": ["inspector_packet", "internal_record"],
            "compliance_notes": [
              "Wind-zone anchoring requirements vary by jurisdiction, manufacturer, and site condition. Verify with AHJ."
            ],
            "conditional_logic": null,
            "sync_policy": "sync_recommended"
          }
        }
      ],
      "source_requirement": "jurisdiction_profile",
      "confidence_level": "medium"
    }
  ],
  "validation_rules": [
    {
      "rule_id": "required_proof_before_inspector_export",
      "rule_type": "missing_proof",
      "severity": "blocking",
      "display_message": "Inspector packet requires all required inspector proof items before export.",
      "applies_to": ["inspector_packet"],
      "conditions": [
        {
          "field": "proof_requirement.priority",
          "operator": "equals",
          "value": "required"
        },
        {
          "field": "proof_requirement.export_tags",
          "operator": "contains",
          "value": "inspector_packet"
        }
      ],
      "recommended_action": "Capture missing required proof or document why it was skipped if allowed."
    },
    {
      "rule_id": "warn_low_quality_required_photos",
      "rule_type": "low_quality_proof",
      "severity": "warning",
      "display_message": "One or more required photos may be blurry, dark, or hard to verify.",
      "applies_to": ["customer_packet", "inspector_packet", "internal_record"],
      "conditions": [
        {
          "field": "proof_object.quality_score",
          "operator": "less_than",
          "value": 0.65
        }
      ],
      "recommended_action": "Retake the photo before leaving the jobsite."
    },
    {
      "rule_id": "warn_missing_gps_on_required_photos",
      "rule_type": "missing_gps",
      "severity": "warning",
      "display_message": "One or more required photos is missing GPS data.",
      "applies_to": ["inspector_packet", "internal_record", "litigation_packet"],
      "conditions": [
        {
          "field": "proof_requirement.requires_gps",
          "operator": "equals",
          "value": true
        },
        {
          "field": "proof_object.gps_latitude",
          "operator": "not_exists"
        }
      ],
      "recommended_action": "Retake proof with location enabled or add an offline location note."
    }
  ]
}
