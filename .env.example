# SITEPROOF_AI_API_URL: Optional local proxy target for a deployed or wrangler dev
# Cloudflare Worker. Browser code calls only /api/ai/*.
SITEPROOF_AI_API_URL="http://localhost:8787"

# PORT: Optional local Express proxy/static server port.
PORT="8787"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
