# SITEPROOF_AI_API_URL: Optional local proxy target for a deployed or wrangler dev
# Cloudflare Worker. Browser code calls only /api/ai/*.
SITEPROOF_AI_API_URL="http://localhost:8787"

# SiteProof app AI/cloud API base (app worker boundary).
# Local Worker default:
VITE_SITEPROOF_API_BASE_URL="http://localhost:8787"
# Production example:
# VITE_SITEPROOF_API_BASE_URL="https://api.siteproof.app"

# SiteProof website billing/license API base (siteproof.report authority).
# This must point to the website/report worker boundary for:
# /api/license/* and /api/checkout/*
# VITE_SITEPROOF_LICENSE_API_BASE_URL="https://api.siteproof.report"

# Cloud Proof Vault uploads. Keep false until signed upload/commit routes are
# verified for the target backend.
VITE_SITEPROOF_CLOUD_VAULT_ENABLED="false"

# PORT: Optional local Express proxy/static server port.
PORT="8787"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
